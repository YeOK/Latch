{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('messages.title') }} — {{ site.name }}{% endblock %}

{% block main_class %} page-messages{% endblock %}

{% block content %}
    <section class="page-header messages-page-header">
        <h1>{{ trans('messages.title') }}</h1>
        <p class="muted">{{ trans('messages.subtitle') }}</p>
    </section>

    {% include 'partials/messages_app.html.twig' with {
        active_conversation_id: active_conversation_id,
        active_conversation: active_conversation
    } %}
{% endblock %}