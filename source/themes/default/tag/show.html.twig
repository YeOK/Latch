{% extends 'layouts/base.html.twig' %}

{% block title %}#{{ tag.name }} — {{ site.name }}{% endblock %}

{% block content %}
    <section class="page-header">
        <p class="breadcrumb"><a href="/">Boards</a> / Tag</p>
        <h1><span class="tag-pill tag-pill-large">#{{ tag.name }}</span></h1>
        <p class="muted">Topics labelled with this tag across all boards.</p>
    </section>

    {% if topics is empty %}
        <p class="empty">No topics with this tag yet.</p>
    {% else %}
        {% include 'partials/topic_list.html.twig' with { topics: topics } %}

        {% if total_pages > 1 %}
            <nav class="pagination">
                {% if page > 1 %}
                    <a href="/tag/{{ tag.slug }}?page={{ page - 1 }}">← Previous</a>
                {% endif %}
                <span>Page {{ page }} of {{ total_pages }}</span>
                {% if page < total_pages %}
                    <a href="/tag/{{ tag.slug }}?page={{ page + 1 }}">Next →</a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}
{% endblock %}