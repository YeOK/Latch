{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('auth.reset_title') }} — {{ site.name }}{% endblock %}

{% block content %}
    <section class="auth-card">
        <h1>{{ trans('auth.reset_title') }}</h1>
        <form method="post" action="/reset-password" class="form">
            {{ csrf_field() }}
            <input type="hidden" name="token" value="{{ token }}">
            <label>
                {{ trans('auth.new_password') }}
                <input type="password" name="password" required autocomplete="new-password" autofocus>
            </label>
            <label>
                {{ trans('auth.confirm_password') }}
                <input type="password" name="password_confirm" required autocomplete="new-password">
            </label>
            <button type="submit" class="btn btn-primary">{{ trans('auth.update_password') }}</button>
        </form>
    </section>
{% endblock %}