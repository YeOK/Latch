{% extends 'layouts/base.html.twig' %}

{% block title %}Two-factor sign in — {{ site.name }}{% endblock %}

{% block content %}
    <section class="auth-card">
        <h1>Two-factor authentication</h1>
        <p class="muted">Enter the 6-digit code from your authenticator app for <strong>{{ username }}</strong>.</p>
        <form method="post" action="/login/2fa" class="form">
            {{ csrf_field() }}
            <label>
                Authentication code
                <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" autofocus required>
            </label>
            <button type="submit" class="btn btn-primary">Verify</button>
        </form>
        <details class="muted" style="margin-top:1rem">
            <summary>Use a recovery code instead</summary>
            <form method="post" action="/login/2fa" class="form" style="margin-top:0.75rem">
                {{ csrf_field() }}
                <label>
                    Recovery code
                    <input type="text" name="recovery_code" placeholder="XXXX-XXXX" autocomplete="off">
                </label>
                <button type="submit" class="btn btn-small">Sign in with recovery code</button>
            </form>
        </details>
        <p class="muted"><a href="/login/2fa/cancel">Back to sign in</a></p>
    </section>
{% endblock %}