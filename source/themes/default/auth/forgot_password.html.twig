{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('auth.forgot_title') }} — {{ site.name }}{% endblock %}

{% block content %}
    <section class="auth-card">
        <h1>{{ trans('auth.forgot_title') }}</h1>
        <p class="muted">{{ trans('auth.forgot_lead') }}</p>
        <form method="post" action="/forgot-password" class="form">
            {{ csrf_field() }}
            <label>
                {{ trans('auth.email') }}
                <input type="email" name="email" required autocomplete="email" autofocus>
            </label>
            <button type="submit" class="btn btn-primary">{{ trans('auth.send_reset_link') }}</button>
        </form>
        <p class="muted"><a href="/login">{{ trans('auth.back_to_sign_in') }}</a></p>
    </section>
{% endblock %}