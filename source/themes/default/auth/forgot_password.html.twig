{% extends 'layouts/base.html.twig' %}

{% block title %}Forgot password — {{ site.name }}{% endblock %}

{% block content %}
    <section class="auth-card">
        <h1>Forgot password</h1>
        <p class="muted">Enter your email and we will send a reset link if the account exists.</p>
        <form method="post" action="/forgot-password" class="form">
            {{ csrf_field() }}
            <label>
                Email
                <input type="email" name="email" required autocomplete="email" autofocus>
            </label>
            <button type="submit" class="btn btn-primary">Send reset link</button>
        </form>
        <p class="muted"><a href="/login">Back to sign in</a></p>
    </section>
{% endblock %}