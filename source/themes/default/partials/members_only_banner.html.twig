{% if members_only and not user %}
    <div class="members-only-banner" role="status">
        <p><strong>{{ trans('members_only.title') }}</strong> {{ trans('members_only.body') }}</p>
        <div class="members-only-actions">
            <a class="btn btn-small btn-primary" href="/login">{{ trans('nav.sign_in') }}</a>
            <a class="btn btn-small" href="/register">{{ trans('nav.register') }}</a>
        </div>
    </div>
{% endif %}