{#
    Unified text field for Latch themes (matches site search styling).

    type:        text | email | password | search | number | url | tel | textarea | select
    name:        field name
    id:          optional element id
    value:       current value
    label:       accessible label text
    placeholder: optional placeholder
    required:    boolean
    disabled:    boolean
    autofocus:   boolean
    minlength:   optional
    maxlength:   optional
    rows:        textarea rows (default 4)
    options:     [{ value, label, selected }] for select fields
    class:       extra classes on the control
    label_class: extra classes on the label wrapper
    hidden:      hide the field
#}
{% set field_type = type|default('text') %}
{% set field_id = id|default(name ~ '-field') %}
{% set field_class = ('field-control ' ~ class|default(''))|trim %}
<label class="field-label{% if label_class|default('') %} {{ label_class }}{% endif %}"{% if hidden|default(false) %} hidden{% endif %}>
    {% if label|default('') %}
        <span class="field-label-text">{{ label }}</span>
    {% endif %}
    {% if field_type == 'textarea' %}
        <textarea
            class="{{ field_class }}"
            id="{{ field_id }}"
            name="{{ name }}"
            rows="{{ rows|default(4) }}"
            {% if placeholder|default('') %}placeholder="{{ placeholder }}"{% endif %}
            {% if required|default(false) %}required{% endif %}
            {% if disabled|default(false) %}disabled{% endif %}
            {% if autofocus|default(false) %}autofocus{% endif %}
            {% if minlength|default('') %}minlength="{{ minlength }}"{% endif %}
            {% if maxlength|default('') %}maxlength="{{ maxlength }}"{% endif %}
        >{{ value|default('') }}</textarea>
    {% elseif field_type == 'select' %}
        <select
            class="{{ field_class }}"
            id="{{ field_id }}"
            name="{{ name }}"
            {% if required|default(false) %}required{% endif %}
            {% if disabled|default(false) %}disabled{% endif %}
        >
            {% for option in options|default([]) %}
                <option value="{{ option.value }}"{% if option.selected|default(false) %} selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
        </select>
    {% else %}
        <input
            class="{{ field_class }}"
            type="{{ field_type }}"
            id="{{ field_id }}"
            name="{{ name }}"
            value="{{ value|default('') }}"
            {% if placeholder|default('') %}placeholder="{{ placeholder }}"{% endif %}
            {% if required|default(false) %}required{% endif %}
            {% if disabled|default(false) %}disabled{% endif %}
            {% if autofocus|default(false) %}autofocus{% endif %}
            {% if minlength|default('') %}minlength="{{ minlength }}"{% endif %}
            {% if maxlength|default('') %}maxlength="{{ maxlength }}"{% endif %}
        >
    {% endif %}
</label>