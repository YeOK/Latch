{# Expects: href, label (used for title + aria-label) #}
<div class="rss-cluster">
    <a class="rss-cluster-btn" href="{{ href }}" title="{{ label }}" aria-label="{{ label }}">
        <svg class="rss-cluster-icon" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="5" cy="19" r="2.25" fill="currentColor"/>
            <path d="M4 11c4.97 0 9 4.03 9 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <path d="M4 5c8.28 0 15 6.72 15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </a>
</div>