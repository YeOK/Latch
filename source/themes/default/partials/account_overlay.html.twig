<div class="account-overlay" id="account-overlay" hidden>
    <div class="account-overlay-backdrop" data-account-close tabindex="-1" aria-hidden="true"></div>
    <div class="account-overlay-dialog" role="dialog" aria-modal="true" aria-labelledby="account-overlay-title">
        <header class="account-overlay-header">
            <div class="account-overlay-header-main">
                <h2 class="account-overlay-title" id="account-overlay-title">{{ trans('overlay.account_title') }}</h2>
                <p class="account-overlay-status muted" id="account-overlay-status" hidden></p>
            </div>
            <button type="button" class="account-overlay-close" data-account-close aria-label="{{ trans('overlay.close_panel') }}">×</button>
        </header>
        <div class="account-overlay-body" id="account-overlay-body">
            <p class="muted account-overlay-loading">{{ trans('common.loading') }}</p>
        </div>
    </div>
</div>