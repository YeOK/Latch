<div class="messages-overlay" id="messages-overlay" hidden>
    <div class="messages-overlay-backdrop" data-messages-close tabindex="-1" aria-hidden="true"></div>
    <div class="messages-overlay-dialog" role="dialog" aria-modal="true" aria-labelledby="messages-overlay-title">
        <header class="messages-overlay-header">
            <h2 class="messages-overlay-title" id="messages-overlay-title">Messages</h2>
            <div class="messages-overlay-actions">
                <a class="messages-overlay-full-page" href="/messages" data-messages-bypass>Open full page</a>
                <button type="button" class="messages-overlay-close" data-messages-close aria-label="Close messages">×</button>
            </div>
        </header>
        <div class="messages-overlay-body" id="messages-overlay-body">
            <p class="muted messages-overlay-loading">Loading…</p>
        </div>
    </div>
</div>