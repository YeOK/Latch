{% extends 'layouts/admin.html.twig' %}

{% block title %}Admin — {{ site.name }}{% endblock %}

{% block admin_content %}
    <section class="page-header">
        <h1>Dashboard</h1>
        <p class="muted">Forum overview{% if open_reports %} · {{ open_reports }} open report{{ open_reports == 1 ? '' : 's' }}{% endif %}</p>
    </section>

    <section class="admin-stats" aria-label="Forum statistics">
        <div class="admin-stat-card">
            <span class="admin-stat-value">{{ post_count }}</span>
            <span class="admin-stat-label">Posts</span>
        </div>
        <a class="admin-stat-card admin-stat-card--link" href="/admin/users">
            <span class="admin-stat-value">{{ user_count }}</span>
            <span class="admin-stat-label">Users</span>
        </a>
        <a class="admin-stat-card admin-stat-card--link" href="/admin/audit">
            <span class="admin-stat-value">{{ audit_log_count }}</span>
            <span class="admin-stat-label">Audit log entries</span>
        </a>
        <a class="admin-stat-card admin-stat-card--link{% if pending_approval %} admin-stat-card--alert{% endif %}" href="/admin/approval">
            <span class="admin-stat-value">{{ pending_approval }}</span>
            <span class="admin-stat-label">Pending approval</span>
        </a>
        <a class="admin-stat-card admin-stat-card--link{% if trash_count %} admin-stat-card--alert{% endif %}" href="/board/mod-trash">
            <span class="admin-stat-value">{{ trash_count|default(0) }}</span>
            <span class="admin-stat-label">Moderation trash</span>
        </a>
        <a class="admin-stat-card admin-stat-card--link{% if quarantine_count %} admin-stat-card--alert{% endif %}" href="/admin/quarantine">
            <span class="admin-stat-value">{{ quarantine_count|default(0) }}</span>
            <span class="admin-stat-label">Quarantined</span>
        </a>
    </section>

    <section class="form-section admin-maintenance">
        <h2>Maintenance</h2>
        <p class="muted">One-click operator tasks. Backups are saved under <code>storage/backups/</code> on the server.</p>

        <div class="admin-site-lock">
            <h3>Site lock (pre-update)</h3>
            {% if site_lock %}
                <p class="muted">Locked since {{ site_lock.enabled_at }}{% if site_lock.enabled_by %} by {{ site_lock.enabled_by }}{% endif %}.</p>
                <p>{{ site_lock.message }}</p>
            {% else %}
                <p class="muted">Stops all web and API traffic without touching the database — use before <code>migrate</code> or file updates. Unlock via <code>/maintenance/unlock</code> (token shown after enable) or <code>sudo -u apache php bin/latch lock off</code>.</p>
                <form method="post" action="/admin/site-lock" class="admin-site-lock-form" data-account-bypass data-confirm="Enable maintenance mode? The forum and API will return 503 until unlocked. Save the unlock token shown after enabling.">
                    {{ csrf_field() }}
                    <label class="muted" for="site-lock-message">Message (optional)</label>
                    <input id="site-lock-message" name="message" type="text" maxlength="240" placeholder="Updating Latch…">
                    <button type="submit" class="btn btn-small btn-primary admin-maintenance-btn">Enable maintenance mode</button>
                </form>
            {% endif %}
        </div>

        <div class="admin-maintenance-actions">
            <form method="post" action="/admin/backup" class="inline-form admin-maintenance-form" data-confirm="Create a backup of the database and local config?">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-small admin-maintenance-btn">
                    {% include 'partials/icon.twig' with { name: 'shield', size: 16 } %}
                    Create backup
                </button>
            </form>
            <form method="post" action="/admin/search-reindex" class="inline-form admin-maintenance-form" data-confirm="Rebuild the full-text search index?">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-small admin-maintenance-btn">
                    {% include 'partials/icon.twig' with { name: 'search', size: 16 } %}
                    Rebuild search
                </button>
            </form>
            <form method="post" action="/admin/cache-clear" class="inline-form admin-maintenance-form" data-confirm="Clear page cache and Twig compile cache?">
                {{ csrf_field() }}
                <button type="submit" class="btn btn-small admin-maintenance-btn">
                    {% include 'partials/icon.twig' with { name: 'dismiss', size: 16 } %}
                    Clear cache
                </button>
            </form>
        </div>
    </section>
{% endblock %}