{% extends 'layouts/base.html.twig' %}

{% block title %}New topic — {{ board.name }}{% endblock %}

{% block content %}
    <section class="page-header">
        <p class="breadcrumb"><a href="/">Boards</a> / <a href="/board/{{ board.slug }}">{{ board.name }}</a> / New topic</p>
        <h1>New topic in {{ board.name }}</h1>
        <p class="muted">Use <strong>**bold**</strong>, <code>`code`</code>, <code>```fences```</code>, <code>[quote]…[/quote]</code>, <code>[spoiler]…[/spoiler]</code>, and emotes like <code>:smile:</code></p>
    </section>

    <form method="post" action="/board/{{ board.slug }}/new" class="form form-compose">
        {{ csrf_field() }}
        <label>
            Title
            <input type="text" name="title" required maxlength="{{ input_limits.topic_title_max }}" autofocus>
        </label>
        <label>
            Tags (optional)
            <input type="text" name="tags" maxlength="200" placeholder="e.g. php, security, announcement" list="tag-suggestions" autocomplete="off">
            <span class="muted">Comma-separated, up to {{ max_tags }} tags.</span>
        </label>
        <datalist id="tag-suggestions"></datalist>
        <label>
            Message
            {% include 'partials/composer.twig' with { draft_key: 'new-topic-' ~ board.slug, required: true, rows: 10, autocomplete: 'one-time-code' } %}
        </label>
        <button type="submit" class="btn btn-primary">Post topic</button>
    </form>
{% endblock %}

{% block scripts %}
    <link rel="stylesheet" href="/assets/css/highlight.css?v={{ asset_version }}">
    <script src="/assets/js/highlight.min.js?v={{ asset_version }}" defer></script>
    <script src="/assets/js/editor.js?v={{ asset_version }}" defer></script>
    <script src="/assets/js/tags.js?v={{ asset_version }}" defer></script>
{% endblock %}