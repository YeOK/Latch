{% extends 'layouts/base.html.twig' %}

{% block title %}{{ trans('legal.privacy_title') }} — {{ site.name }}{% endblock %}

{% block content %}
    <section class="page-header">
        <h1>{{ trans('legal.privacy_title') }}</h1>
        <p class="muted">{{ trans('legal.privacy_lead', { operator: operator_name }) }}</p>
    </section>

    <article class="legal-doc card">
        <h2>{{ trans('legal.privacy_controller') }}</h2>
        <p>{{ trans('legal.privacy_controller_body', { operator: operator_name }) }}{% if contact_email %} (<a href="mailto:{{ contact_email }}">{{ contact_email }}</a>){% endif %}.</p>
        <p>{{ trans('legal.privacy_latch_note')|replace({'Latch': '<strong>Latch</strong>'})|raw }}</p>

        <h2>{{ trans('legal.privacy_collect') }}</h2>
        <ul>
            <li>{{ trans('legal.privacy_collect_account')|replace({'Account data': '<strong>Account data</strong>'})|raw }}</li>
            <li>{{ trans('legal.privacy_collect_content')|replace({'Content': '<strong>Content</strong>'})|raw }}</li>
            <li>{{ trans('legal.privacy_collect_security')|replace({'Security & session data': '<strong>Security &amp; session data</strong>'})|raw }}</li>
            <li>{{ trans('legal.privacy_collect_prefs')|replace({'Preferences': '<strong>Preferences</strong>'})|raw }}</li>
        </ul>

        <h2>{{ trans('legal.privacy_why') }}</h2>
        <ul>
            <li>{{ trans('legal.privacy_why_service') }}</li>
            <li>{{ trans('legal.privacy_why_security') }}</li>
            <li>{{ trans('legal.privacy_why_moderation') }}</li>
        </ul>

        <h2>{{ trans('legal.privacy_rights') }}</h2>
        <p>{{ trans('legal.privacy_rights_body') }}</p>
        <ul>
            <li>{{ trans('legal.privacy_export')|replace({'Export your data': '<a href="/profile/export">Export your data</a>'})|raw }}</li>
            <li>{{ trans('legal.privacy_delete')|replace({'your profile': '<a href="/profile">your profile</a>'})|raw }}</li>
            <li>{{ trans('legal.privacy_contact') }}{% if contact_email %} at <a href="mailto:{{ contact_email }}">{{ contact_email }}</a>{% endif %}.</li>
        </ul>

        <h2>{{ trans('legal.privacy_retention') }}</h2>
        <p>{{ trans('legal.privacy_retention_body') }}</p>

        <h2>{{ trans('legal.privacy_processors') }}</h2>
        <p>{{ trans('legal.privacy_processors_body', { operator: operator_name }) }}</p>

        <p class="muted legal-updated">{{ trans('legal.last_updated', { date: "now"|date("Y-m-d") }) }}</p>
    </article>
{% endblock %}