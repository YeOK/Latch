{
    "name": "Image upload (R2)",
    "slug": "image-upload",
    "version": "1.0.0",
    "min_latch_version": "0.3.0",
    "description": "Insert post images via direct browser upload to Cloudflare R2 (images.forum.example.com).",
    "hooks": [
        "route.register",
        "theme.assets",
        "theme.scripts",
        "editor.compose",
        "post.format.image_host",
        "csp.img_src",
        "csp.connect_src",
        "post.before_save"
    ],
    "permissions": {
        "filesystem": [],
        "network": [],
        "config": [
            "plugins.image_upload"
        ]
    }
}