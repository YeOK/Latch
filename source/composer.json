{
    "name": "latch/forum",
    "description": "Latch — fast, secure, self-hosted PHP forum",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "bacon/bacon-qr-code": "^3.0",
        "twig/twig": "^3.14"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Latch\\": "app/",
            "Latch\\Plugins\\MdImport\\": "plugins/md-import/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Latch\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}